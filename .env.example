BEAV3R_URL=https://server.beav3r.ai
BEAV3R_API_KEY=replace-me
BEAV3R_ORIGIN_LABEL=
BEAV3R_ORIGIN_TYPE=openclaw
OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18789
OPENCLAW_STATE_HOST_PATH=$HOME/.openclaw
OPENCLAW_STATE_DIR=/openclaw-state
CALLBACK_SECRET=replace-with-random-secret
CALLBACK_KEY_ID=k1
PLUGIN_PUBLIC_URL=http://plugin:7771
PLUGIN_HOST=0.0.0.0
PLUGIN_PORT=7771
PLUGIN_HOST_PORT=7771
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=7772
BRIDGE_HOST_PORT=7772
BRIDGE_URL=http://bridge:7772
BEAV3R_TIMEOUT_MS=3000
BRIDGE_POLL_MS=1500
CALLBACK_RETRIES=2
CALLBACK_BACKOFF_MS=100
PENDING_TIMEOUT_SEC=300
EXPIRE_SKEW_SEC=0
RISK_LOCAL_MAX=30
RISK_BEAV3R_MIN=70
FALLBACK_MEDIUM=local
FALLBACK_HIGH=deny
