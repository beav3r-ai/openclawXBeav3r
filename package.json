{
  "name": "openclawxbeav3r",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/beav3r-ai/openclawXBeav3r.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run --workspaces build",
    "test": "npm run --workspaces test",
    "demo": "tsx examples/demo-simulate.ts",
    "bridge": "npm run --workspace @beav3r/openclaw-beav3r-bridge start",
    "plugin": "npm run --workspace @openclaw/openclaw-approvals start",
    "plugin:openclaw": "npm run --workspace @openclaw/openclaw-approvals start:openclaw",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "install:docker": "sh scripts/install-docker.sh",
    "bootstrap:docker": "sh scripts/bootstrap-docker.sh"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
